{
  "kind": "collectionType",
  "collectionName": "playlists",
  "info": {
    "singularName": "playlist",
    "pluralName": "playlists",
    "displayName": "playlists",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "playlistTitle": {
      "type": "string",
      "required": true,
      "maxLength": 200,
      "unique": true,
      "minLength": 4
    },
    "playlistAuthor": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "minLength": 3
    },
    "videos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::video.video",
      "mappedBy": "playlistName"
    },
    "totalVideos": {
      "type": "integer"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
