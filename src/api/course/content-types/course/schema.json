{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "courseTitle": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 200,
      "minLength": 4
    },
    "courseContent": {
      "type": "richtext",
      "required": true
    },
    "courseLecture": {
      "allowedTypes": [
        "videos"
      ],
      "type": "media",
      "multiple": false,
      "required": true
    },
    "author": {
      "type": "string",
      "required": true,
      "minLength": 3,
      "maxLength": 100
    },
    "lectureThumbnail": {
      "allowedTypes": [
        "images"
      ],
      "type": "media",
      "multiple": false,
      "required": true
    },
    "isPopular": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "views": {
      "type": "integer"
    },
    "duration": {
      "type": "string",
      "required": true
    }
  }
}
