{
  "kind": "collectionType",
  "collectionName": "videos",
  "info": {
    "singularName": "video",
    "pluralName": "videos",
    "displayName": "videos",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "videoTitle": {
      "type": "string"
    },
    "videoContent": {
      "type": "richtext",
      "required": true,
      "maxLength": 5000,
      "minLength": 50
    },
    "video": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "videos"
      ]
    },
    "author": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "minLength": 3
    },
    "videoThumbnail": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "isPopular": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "views": {
      "type": "integer"
    },
    "playlistName": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::playlist.playlist",
      "inversedBy": "videos"
    },
    "duration": {
      "type": "integer",
      "required": true
    }
  }
}
